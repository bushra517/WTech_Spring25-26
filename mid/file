                <label for="sname">Second Name</label>
                <input type="text" id="sname">
            </div>
             <div>
                <label for="age">Age</label>
                <input type="text" id="age">
            </div>

            <button id="btn" type="button">Check</button>
        </div>
       <p id="demo"></p>
     </form>

     <script >
     let finput = document.getElementById('fname')
let sinput = document.getElementById('sname')
let ageinput = document.getElementById('age')
let para = document.getElementById('demo')
let checkbtn = document.getElementById('btn')


checkbtn.addEventListener('click', function(e){
    e.preventDefault();

    if(ageinput.value > 18){
        para.innerText = "Name: " + finput.value + " "+ sinput.value + " age: " + ageinput.value + " comment: You are adult"
    }
    else if(isNaN(ageinput)){
        para.innerText = "Not valid"
    }
    else{
        para.innerText = "Name: " + finput.value + sinput.value + " age: " + ageinput.value + "comment: You are Minor"
    }

})   </script>
</body>
</html>